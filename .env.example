# Supabase configuration
# Copy this file to `.env` and fill in the values from your Supabase project.
# Dashboard → Project Settings → API
#
# IMPORTANT: Only use the `anon public` key here. Never put the `service_role`
# key in client code — it bypasses RLS and would expose every user's data.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
